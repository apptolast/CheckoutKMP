# Normalize line endings: store text as LF in the repo, check out native on Windows.
* text=auto eol=lf

# Explicit text types
*.kt      text eol=lf
*.kts     text eol=lf
*.java    text eol=lf
*.xml     text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.pro     text eol=lf
*.properties text eol=lf
*.swift   text eol=lf

# Windows-only scripts must keep CRLF
*.bat     text eol=crlf
# Unix shell scripts must keep LF
gradlew   text eol=lf
*.sh      text eol=lf

# Binary assets (never touch line endings)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.webp    binary
*.gif     binary
*.jar     binary
*.keystore binary
